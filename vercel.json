{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install && npm run build:content-manifests",
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/[...route].ts": {
      "includeFiles": "server/generated/content/*.json",
      "excludeFiles": "client/public/**",
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/designcircle",
      "destination": "/creative/portfolio",
      "permanent": true
    },
    {
      "source": "/gallery",
      "destination": "/creative/gallery",
      "permanent": true
    },
    {
      "source": "/creative/blog",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/creative/journey",
      "destination": "/creative/visual-designs",
      "permanent": true
    },
    {
      "source": "/codecircle",
      "destination": "/codecircle/portfolio",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/"
    }
  ]
}
