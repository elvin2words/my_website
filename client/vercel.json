{
  "redirects": [
    {
      "source": "/engineer/portfolio",
      "destination": "/engineer",
      "permanent": true
    },
    {
      "source": "/engineer/journey",
      "destination": "/engineer",
      "permanent": true
    },
    {
      "source": "/designcircle",
      "destination": "/creative/portfolio",
      "permanent": true
    },
    {
      "source": "/gallery",
      "destination": "/creative/gallery",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/creative/blog",
      "permanent": true
    },
    {
      "source": "/creative/visual-designs",
      "destination": "/creative/journey",
      "permanent": true
    },
    {
      "source": "/codecircle/journey",
      "destination": "/codecircle/portfolio",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!api(?:/|$)|assets/|.*\\..*).*)",
      "destination": "/"
    }
  ]
}
